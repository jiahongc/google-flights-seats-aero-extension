{
  "manifest_version": 3,
  "name": "Seats.aero for Google Flights",
  "version": "1.7.0",
  "description": "Search award flight availability on seats.aero directly from Google Flights",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "*://www.google.com/travel/flights/*",
    "*://seats.aero/*",
    "*://api.frankfurter.dev/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.google.com/travel/*"],
      "js": ["airlines.js", "metros.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://seats.aero/*"],
      "js": ["protobuf.js", "seats-content.js"],
      "css": ["seats-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
